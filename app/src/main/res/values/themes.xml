<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.LibraryApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Κύρια Χρώματα (Μπλε) -->
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorPrimaryVariant">#1557B0</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Δευτερεύοντα Χρώματα (Το πράσινο για το Active Status) -->
        <!-- Το κύριο πράσινο για εικονίδια/κείμενο -->
        <item name="colorSecondary">#2E7D32</item>
        <!-- Το φόντο του επιλεγμένου στοιχείου (Πολύ ανοιχτό πράσινο) -->
        <item name="colorSecondaryVariant">#E8F5E9</item>
        <item name="colorOnSecondary">#1B5E20</item>

        <!-- Χρώματα Επιφανειών -->
        <item name="android:windowBackground">#F8F9FA</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#202124</item>
        <item name="colorError">#B00020</item>
        <item name="colorOnError">#FFFFFF</item>

        <!-- Κρίσιμα Attributes για το NavigationView και το σύστημα -->
        <item name="android:textColorPrimary">#202124</item>
        <item name="android:textColorSecondary">#5F6368</item>
        <item name="android:textColorPrimaryDisableOnly">#9E9E9E</item>
        <item name="colorControlNormal">#5F6368</item>
        <item name="colorControlActivated">#1A73E8</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>